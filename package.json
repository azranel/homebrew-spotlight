{
  "name": "spotlight",
  "version": "0.1.0",
  "description": "CLI tool to sync git worktree changes to the main repository as checkpoints",
  "type": "module",
  "bin": {
    "spotlight": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --outdir=dist --target=bun src/index.ts && cp dist/index.js dist/spotlight && chmod +x dist/spotlight",
    "build:compile": "bun build --compile --outfile=spotlight src/index.ts",
    "build:compile:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile=spotlight-darwin-arm64 src/index.ts",
    "build:compile:darwin-x64": "bun build --compile --target=bun-darwin-x64 --outfile=spotlight-darwin-x64 src/index.ts",
    "build:compile:linux-x64": "bun build --compile --target=bun-linux-x64 --outfile=spotlight-linux-x64 src/index.ts",
    "lint": "oxlint -c oxlintrc.json src/",
    "test": "bun test"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "latest"
  }
}
